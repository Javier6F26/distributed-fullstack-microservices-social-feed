# API Gateway Environment Variables
# Configuration matches Postman environment variables

# Server Configuration - API Gateway runs on port 3000
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:4200

# Microservice URLs (matching Postman environment)
USER_SERVICE_URL=http://localhost:3001
POST_SERVICE_URL=http://localhost:3002
COMMENT_SERVICE_URL=http://localhost:3003

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_REFRESH_MAX=30

# JWT Secret (shared with user-service for validation)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars-recommended
