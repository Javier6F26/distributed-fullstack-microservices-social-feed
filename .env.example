# =============================================================================
# Environment Variables - Desarrollo Local
# =============================================================================
# Copia este archivo a .env
# cp .env.example .env
# =============================================================================

# ------------------------- JWT Secrets (REQUIRED) -------------------------
# Generar secretos únicos: openssl rand -base64 32
JWT_SECRET=tu-secreto-super-seguro-min-32-caracteres-cambia-esto
JWT_REFRESH_SECRET=tu-secreto-de-refresco-super-seguro-cambia-esto

# ------------------------- MongoDB -------------------------
# Cada servicio usa la misma instancia pero diferente database
MONGODB_URI_USER=mongodb://localhost:27017/user-service
MONGODB_URI_POST=mongodb://localhost:27017/post-service
MONGODB_URI_COMMENT=mongodb://localhost:27017/comment-service

# ------------------------- RabbitMQ -------------------------
RABBITMQ_URI=amqp://admin:admin@localhost:5672

# ------------------------- Redis -------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------- Puertos -------------------------
API_GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
POST_SERVICE_PORT=3002
COMMENT_SERVICE_PORT=3003
FRONTEND_PORT=4200

# ------------------------- URLs de Servicios -------------------------
# Para API Gateway (llamadas internas entre servicios)
USER_SERVICE_URL=http://localhost:3001
POST_SERVICE_URL=http://localhost:3002
COMMENT_SERVICE_URL=http://localhost:3003

# ------------------------- CORS -------------------------
CORS_ORIGIN=http://localhost:4200

# ------------------------- Logging -------------------------
LOG_LEVEL=debug

# ------------------------- Rate Limiting -------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ------------------------- JWT Expiración -------------------------
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
