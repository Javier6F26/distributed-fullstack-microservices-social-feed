# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your production values
# NEVER commit .env to version control!
# =============================================================================

# ------------------------- Application Settings -------------------------
# Your production domain (for CORS)
CORS_ORIGIN=https://your-production-domain.com

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# ------------------------- JWT Secrets (REQUIRED) -------------------------
# Generate strong random secrets (min 32 characters recommended)
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production

# ------------------------- MongoDB Connection -------------------------
# Format: mongodb://[username:password@]host:port/database[?options]
# For production, use authentication and SSL
MONGODB_URI=mongodb://mongodb:27017/app

# ------------------------- RabbitMQ Configuration -------------------------
# Format: amqp://username:password@host:port
RABBITMQ_URI=amqp://admin:admin@rabbitmq:5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change-me-in-production
