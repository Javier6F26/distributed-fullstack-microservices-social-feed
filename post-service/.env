# Post Service Environment Variables
# Configuration matches Postman environment variables

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/posts

# Server Configuration - Post Service runs on port 3002
PORT=3002
NODE_ENV=development

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Configuration (for event-driven architecture)
RABBITMQ_URI=amqp://localhost:5672

# API Gateway URL (for callbacks if needed)
API_GATEWAY_URL=http://localhost:3000