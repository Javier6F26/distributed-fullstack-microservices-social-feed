# User Service Environment Variables
# Configuration matches Postman environment variables

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/users

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars-recommended
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server Configuration - User Service runs on port 3001
PORT=3001
NODE_ENV=development

# CORS Configuration (for api-gateway)
CORS_ORIGIN=http://localhost:4200

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=30

# Refresh Token Cleanup (milliseconds between cleanup runs)
REFRESH_TOKEN_CLEANUP_INTERVAL_MS=3600000
